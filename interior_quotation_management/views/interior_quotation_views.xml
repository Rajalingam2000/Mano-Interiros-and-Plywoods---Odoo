<odoo>
    <data>

        <!-- ===============================
             Action Window
        =============================== -->
        <record id="action_interior_quotation" model="ir.actions.act_window">
            <field name="name">Interior Quotations</field>
            <field name="res_model">interior.quotation</field>
            <field name="view_mode">kanban,tree,form,pivot,graph</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first interior quotation.
                </p>
            </field>
        </record>

        <!-- ===============================
             Tree View
        =============================== -->
        <record id="view_interior_quotation_tree" model="ir.ui.view">
            <field name="name">interior.quotation.tree</field>
            <field name="model">interior.quotation</field>
            <field name="arch" type="xml">
                <tree string="Interior Quotations">
                    <field name="name"/>
                    <field name="project_name"/>
                    <field name="partner_id"/>
                    <field name="date"/>
                    <field name="state"/>
                    <field name="user_id"/>
                </tree>
            </field>
        </record>

        <!-- ===============================
             Kanban View
        =============================== -->
<record id="view_interior_quotation_kanban" model="ir.ui.view">
    <field name="name">interior.quotation.kanban</field>
    <field name="model">interior.quotation</field>
    <field name="arch" type="xml">
        <kanban class="o_kanban_mobile" sample="1">
            <templates>
                <t t-name="kanban-box">
                    <div
                        t-attf-class="oe_kanban_global_click"
                        style="
                            background-color: #FFFFFF;
                            border: 1px solid #E0E0E0;
                            border-radius: 8px;
                            padding: 16px;
                            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
                            transition: transform 0.2s ease, box-shadow 0.2s ease;
                        "
                        onmouseover="this.style.boxShadow='0 8px 16px rgba(0, 0, 0, 0.2)'; this.style.transform='scale(1.05)';"
                        onmouseout="this.style.boxShadow='0 4px 8px rgba(0, 0, 0, 0.1)'; this.style.transform='scale(1)';"
                    >
                        <!-- Partner Name -->
                        <div style="font-size: 20px; font-weight: 700; color: #2C3E50; margin-bottom: 8px;">
                            <field name="partner_id"/>
                        </div>

                        <!-- Address -->
                        <div style="font-size: 16px; font-weight: 400; color: #7F8C8D; margin-bottom: 12px; text-align: right;">
                            <field name="address"/>
                        </div>

                        <!-- Quotation Details -->
                        <div class="oe_kanban_details" style="margin-top: 10px;">
                            <ul style="list-style-type: none; padding: 0;">
                                <!-- Material Total (Amount) -->
                                <li style="margin-bottom: 12px; display: flex; justify-content: space-between;">
                                    <span style="font-size: 14px; font-weight: 500; color: #FF5722;">Amount:</span>
                                    <span style="font-size: 16px; font-weight: 600; color: #FF5722;">
                                        <field name="material_total"/>
                                    </span>
                                </li>

                                <!-- Reference -->
                                <li style="margin-bottom: 8px; display: flex; justify-content: space-between;">
                                    <span style="font-size: 14px; font-weight: 500; color: #FF5722;">Reference:</span>
                                    <span style="font-size: 16px; font-weight: 600; color: #FF5722;">
                                        <field name="name"/>
                                    </span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>




        <!-- ===============================
             Form View
        =============================== -->
        <record id="view_interior_quotation_form" model="ir.ui.view">
            <field name="name">interior.quotation.form</field>
            <field name="model">interior.quotation</field>
            <field name="arch" type="xml">
                <form string="Interior Quotation" create="true" edit="true">
                    <header>
                        <button name="action_send" type="object" string="Send" class="btn-primary"
                                />
<!--                        invisible="state != 'approved'"-->
                        <button name="action_approve" type="object" string="Approve" class="btn-success"
                                invisible="state in ('approved','sent','rejected')"/>
                        <button name="action_reject" type="object" string="Reject" class="btn-danger"/>
                        <button name="action_duplicate_revision" type="object" string="Duplicate for Revision"
                                class="btn-secondary"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,approved,rejected"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h2>
                                <field name="name"/>
                            </h2>
                        </div>

                        <group>
                            <group>
                                <field name="partner_id"/>
                                <field name="project_name"/>
                                <field name="address"/>
                                <field name="user_id"/>
                            </group>
                            <group>
                                <field name="quotation_title"/>
                                <field name="date"/>
                                <field name="validity_days"/>
                                <field name="date_deadline"/>
                                <field name="revision" readonly="1"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="Materials">
                                <field name="material_line_ids" widget="section_and_note_one2many">
                                    <tree editable="bottom">
                                        <field name="product_id"/>
                                        <field name="qty"/>
                                        <field name="width"/>
                                        <field name="height"/>
                                        <field name="sqft" readonly="1"/>
                                        <field name="rate"/>
                                        <field name="amount" readonly="1"/>
                                    </tree>
                                </field>
                            </page>

                            <page string="Notes">
                                <field name="note"/>
                            </page>
                        </notebook>
                        <field name="material_total" string="Total"/>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ===============================
             Search View
        =============================== -->
        <record id="view_interior_quotation_search" model="ir.ui.view">
            <field name="name">interior.quotation.search</field>
            <field name="model">interior.quotation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="partner_id"/>
                    <field name="project_name"/>
                    <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                    <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                </search>
            </field>
        </record>

    </data>
</odoo>
