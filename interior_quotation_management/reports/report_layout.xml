<odoo>
    <!-- Report Content -->
    <template id="report_interior_quotation_content_template">
        <t t-call="web.external_layout">
            <div class="page" style="font-family: Arial, sans-serif; font-size: 14px;">
                <!-- Client & Quotation Info -->

                <h1 class="text-center mt-3"
                    style="font-size: 22px; font-weight: 700; color: #E68C6A; font-family: Arial, sans-serif;">
                    <t t-esc="o.quotation_title"/>
                </h1>


                <!-- ======================== -->
                <!-- Client & Quotation Details -->
                <!-- ======================== -->
                <!-- Client & Quotation Info (Bootstrap Grid Layout) -->
                <div class="container" style="margin-bottom:25px; font-family:Arial, sans-serif; font-size:14px;">
                    <div class="row">

                        <!-- Left Box -->
                        <div class="col-6">
                            <div style="padding:15px 18px; border-radius:8px; height:100%;">
                                <div style="margin-bottom:8px;">
                                    <span style="font-weight:600; color:#333;">Client:</span>
                                    <span style="font-weight:500; color:#111; margin-left:6px;">
                                        <t t-esc="o.partner_id.name"/>
                                    </span>
                                </div>
                                <div>
                                    <span style="font-weight:600; color:#333;">Location:</span>
                                    <span style="font-weight:500; color:#111; margin-left:6px;">
                                        <t t-esc="o.address"/>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Right Box -->
                        <div class="col-6">
                            <div style="padding:15px 18px; border-radius:8px; height:100%;">
                                <div style="margin-bottom:8px;">
                                    <span style="font-weight:600; color:#333;">Date:</span>
                                    <span style="font-weight:500; color:#111; margin-left:6px;">
                                        <t t-esc="o.date"/>
                                    </span>
                                </div>
                                <div>
                                    <span style="font-weight:600; color:#333;">Quotation Ref:</span>
                                    <span style="font-weight:500; color:#111; margin-left:6px;">
                                        <t t-esc="o.name"/>
                                    </span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>


                <!-- ======================== -->
                <!-- Materials Table (Detailed) -->
                <!-- ======================== -->
                <div style="margin-top:10px; border-top:3px solid #b22222; padding-top:5px;">
                    <h3 style="font-size:16px; font-weight:700; color:#b22222; margin-bottom:8px; font-family:Arial, sans-serif;">
                        Materials &amp; Cost Details
                    </h3>

                    <table style="width:100%; border:1px solid #000; border-collapse:collapse; font-family:Arial, sans-serif; font-size: 15px;">
                        <thead style="background-color:#f3f3f3;">
                            <tr style="color:#b22222; text-transform:uppercase;">
                                <th style="border:1px solid #000; padding:8px; text-align:center; width:5%;">S.No</th>
                                <th style="border:1px solid #000; padding:8px; text-align:left;">Name</th>
                                <th style="border:1px solid #000; padding:8px; text-align:center;">Quantity</th>
                                <th style="border:1px solid #000; padding:8px; text-align:center;">Size</th>
                                <th style="border:1px solid #000; padding:8px; text-align:center;">Sqft</th>
                                <th style="border:1px solid #000; padding:8px; text-align:right;">Amount</th>
                            </tr>
                        </thead>

                        <tbody>
                            <t t-set="slno" t-value="1" />
                            <tr t-foreach="o.material_line_ids" t-as="line" t-foreach-index="i"
                                t-attf-class="#{(i or 0) % 2 == 0 and 'even-row' or 'odd-row'}">
                                <td style="border:1px solid #000; padding:6px; text-align:center;">
                                    <span t-esc="slno" />
                                    <t t-set="slno" t-value="slno+1" />
                                </td>
                                <td style="border:1px solid #000; padding:6px;">
                                    <t t-esc="line.product_id.name"/>
                                </td>
                                <td style="border:1px solid #000; padding:6px; text-align:center;">
                                    <t t-esc="line.qty"/>
                                </td>
                                <td style="border:1px solid #000; padding:6px; text-align:center;">
                                    <t t-esc="line.width"/>
                                    ×
                                    <t t-esc="line.height"/>
                                </td>
                                <td style="border:1px solid #000; padding:6px; text-align:center;">
                                    <t t-esc="line.sqft"/>
                                    ×
                                    <t t-esc="line.rate"/>
                                </td>
                                <td style="border:1px solid #000; padding:6px; text-align:right;">
                                    <t t-esc="line.amount"/>
                                </td>
                            </tr>
                        </tbody>
                    </table><!-- Total displayed outside table -->
<div style="margin-top:10px; text-align:right;">
    <span style="font-size:16px; font-weight:900; color:#c1121f; padding:10px 15px; border:1px solid #000; background-color:#fdf2f2; display:inline-block; border-radius:4px;">
        Total:
        <t t-esc="o.material_total"
           t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
    </span>
</div>

                </div>


                <!-- Internal Notes Section -->
                <t t-if="o.note">
                    <div style="margin-top: 30px; font-family: Arial, sans-serif; font-size: 14px;">
                        <div style="color: #111; line-height: 1.5;">
                            <t t-out="o.note"/>
                        </div>
                    </div>
                </t>

                <!-- Prepared By Section -->
                <div style="
                    bottom: 30px;
                    right: 40px;
                    font-family: Arial, sans-serif;
                    font-size: 16px;
                    text-align: right;
                ">
                    <span style="font-weight:600; color:#333;">Prepared By:</span>
                    <span style="font-weight:600; color:#e67e22;">
                        <t t-esc="o.user_id.name"/>
                    </span>
                </div>


            </div>
        </t>
    </template>

    <!-- External Layout -->
    <template id="external_layout_quotation">
        <t t-if="not o" t-set="o" t-value="doc"/>
        <t t-set="company" t-value="o.env.user.company_id"/>

        <!-- HEADER -->
        <div class="header"
             style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 25px;">
            <!-- Company Logo -->
            <div style="flex-shrink: 0;">
                <t t-if="company.logo">
                    <img t-att-src="image_data_uri(company.logo)" style="max-height: 80px;" alt="Logo"/>
                </t>
            </div>

            <!-- Company Name & Info -->
            <div style="text-align: right;">
                <h1 style="margin: 0; font-size: 30px; font-weight: bold; color:#b22222;">
                    <t t-esc="company.name"/>
                </h1>
                <div style="font-size: 12px; line-height: 1.3; color: #111;">
                    <t t-if="company.email">Email:
                        <t t-esc="company.email"/>
                    </t>
                    <t t-if="company.phone">| Phone:
                        <t t-esc="company.phone"/>
                    </t>
                    <t t-if="company.street">
                        <br/>
                        <t t-esc="company.street"/>
                    </t>
                    <t t-if="company.street2">
                        <t t-esc="company.street2"/>
                    </t>
                    <t t-if="company.vat"><br/>GST:
                        <t t-esc="company.vat"/>
                    </t>
                </div>
            </div>
        </div>
        <hr style="border:1px solid #000; margin-bottom:20px;"/>

        <hr style="border:1px solid #000; margin-bottom:20px;"/>

        <!-- Body content -->
        <div class="article o_report_layout_standard o_company_#{company.id}_layout">
            <t t-out="0"/>
        </div>
    </template>
</odoo>
