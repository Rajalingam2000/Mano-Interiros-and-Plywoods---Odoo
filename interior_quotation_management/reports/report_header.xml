<odoo>
    <template id="report_quotation_custom_header">
        <!-- Safely get the company -->
        <t t-set="company" t-value="o.company_id.sudo() if o and hasattr(o, 'company_id') else env.company"/>

        <div class="header" style="margin-bottom: 20px;">
            <div style="display: flex; align-items: center; justify-content: space-between;">

                <!-- Company Logo -->
                <div>
                    <t t-if="company.logo">
                        <img t-att-src="'data:image/png;base64,%s' % company.logo.decode('utf-8') if company.logo else ''"
                             style="max-height: 60px;"/>
                    </t>
                </div>

                <!-- Company Info -->
                <div style="flex: 1; margin-left: 15px; text-align: right;">
                    <h2 style="font-size: 30px; margin: 0;">
                        <t t-esc="company.name"/>
                    </h2>
                    <div style="font-size: 12px; line-height: 1.3;">
                        <t t-if="company.email">Email: <t t-esc="company.email"/></t>
                        <t t-if="company.phone"> | Phone: <t t-esc="company.phone"/></t>
                        <t t-if="company.street"><br/><t t-esc="company.street"/></t>
                        <t t-if="company.street2"><t t-esc="company.street2"/></t>
                        <t t-if="company.vat"><br/>GST: <t t-esc="company.vat"/></t>
                    </div>
                </div>
            </div>
            <hr style="border: 1px solid #000; margin-top: 10px;"/>
        </div>
    </template>
</odoo>
