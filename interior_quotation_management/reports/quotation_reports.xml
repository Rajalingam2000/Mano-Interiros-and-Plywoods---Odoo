<odoo>

    <template id="report_interior_quotation">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="lang" t-value="o.partner_id.lang"/>
                <t
                        t-call="interior_quotation_management.report_interior_quotation_content_template"
                        t-lang="lang"
                        style="border: 1px solid #000; padding: 20px; box-sizing: border-box; margin-bottom:20px;"
                />
            </t>
        </t>
    </template>


    <record id="action_report_interior_quotation" model="ir.actions.report">
        <field name="name">Interior Interior</field>
        <field name="model">interior.quotation</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">interior_quotation_management.report_interior_quotation</field>
        <field name="report_file">interior_quotation_management.report_interior_quotation</field>
        <field name="binding_model_id" ref="interior_quotation_management.model_interior_quotation"/>
        <field name="print_report_name">(object.name or 'Quotation')</field>
    </record>

</odoo>
